---
interface Preview {
  image: string;
  alt: string;
  caption: string;
  features: string[];
}

interface Props {
  copy: {
    headline: string;
    subheadline: string;
    previews: Preview[];
  };
}

const { copy } = Astro.props;
---

<section id="app-preview" class="section">
  <div class="shell">
    <h2>{copy.headline}</h2>
    <p class="section-lead">{copy.subheadline}</p>

    <div class="story-layout">
      <div class="story-topbar">
        <p class="story-topbar-kicker">Product Tour</p>
        <nav class="story-nav" aria-label="DealDroid product tour">
          {copy.previews.map((preview, idx) => (
            <button
              class={idx === 0 ? 'story-tab active' : 'story-tab'}
              data-story-tab={idx}
              aria-selected={idx === 0}
              type="button"
            >
              <span class="story-tab-index">0{idx + 1}</span>
              <span class="story-tab-label">{preview.caption}</span>
              <span class="story-tab-summary">{preview.features[0]}</span>
            </button>
          ))}
        </nav>
      </div>

      <div class="story-steps">
        {copy.previews.map((preview, idx) => (
          <article class={idx === 0 ? 'story-step active' : 'story-step'} data-story-step={idx} id={`story-step-${idx}`}>
            <div class="story-step-copy">
              <p class="story-kicker">Screen {idx + 1}</p>
              <h3>{preview.caption}</h3>
              <div class="preview-features">
                {preview.features.map((feature) => (
                  <div class="feature-item">
                    <span class="feature-icon">✓</span>
                    <p>{feature}</p>
                  </div>
                ))}
              </div>
            </div>

            <figure class="story-step-image">
              <img src={preview.image} alt={preview.alt} loading="lazy" />
            </figure>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const previewSection = document.querySelector('#app-preview');

  if (previewSection) {
    const storyTabs = Array.from(previewSection.querySelectorAll('.story-tab'));
    const storySteps = Array.from(previewSection.querySelectorAll('.story-step'));

    const setActiveStory = (index = 0) => {
      storyTabs.forEach((tab, idx) => {
        const isActive = idx === index;
        tab.classList.toggle('active', isActive);
        tab.setAttribute('aria-selected', String(isActive));
      });

      storySteps.forEach((step, idx) => {
        step.classList.toggle('active', idx === index);
      });
    };

    storyTabs.forEach((tab, idx) => {
      tab.addEventListener('click', () => {
        storySteps[idx]?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        setActiveStory(idx);
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        const visibleEntries = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

        if (visibleEntries.length === 0) return;

        const activeIndex = Number(visibleEntries[0].target.getAttribute('data-story-step'));
        if (!Number.isNaN(activeIndex)) {
          setActiveStory(activeIndex);
        }
      },
      {
        rootMargin: '-25% 0px -25% 0px',
        threshold: [0.35, 0.6, 0.85],
      }
    );

    storySteps.forEach((step) => observer.observe(step));
  }
</script>

<style>
  .story-layout {
    display: grid;
    gap: 1.5rem;
    margin-top: 2rem;
    align-items: start;
  }

  .story-topbar {
    position: sticky;
    top: 0.2rem;
    z-index: 4;
    display: grid;
    gap: 0.9rem;
    padding: 1.15rem;
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(10px);
    box-shadow: 0 16px 38px rgba(107, 114, 128, 0.08);
  }

  .story-topbar-kicker {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand);
  }

  .story-nav {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .story-tab {
    display: grid;
    gap: 0.3rem;
    align-content: start;
    padding: 0.95rem 1rem;
    text-align: left;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: rgba(249, 250, 251, 0.88);
    color: var(--muted);
    cursor: pointer;
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
  }

  .story-tab:hover {
    transform: translateY(-1px);
    color: var(--ink);
    box-shadow: 0 8px 18px rgba(107, 114, 128, 0.08);
  }

  .story-tab.active {
    background: linear-gradient(180deg, rgba(79, 70, 229, 0.08), rgba(79, 70, 229, 0.03));
    border-color: rgba(79, 70, 229, 0.3);
    color: var(--ink);
    box-shadow: 0 14px 28px rgba(79, 70, 229, 0.12);
  }

  .story-tab-index {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--brand);
    letter-spacing: 0.08em;
  }

  .story-tab-label {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .story-tab-summary {
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--muted);
  }

  .story-tab.active .story-tab-summary {
    color: #475569;
  }

  .story-steps {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .story-step {
    scroll-margin-top: 9.5rem;
    min-height: 72vh;
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: 1.35rem;
    align-items: center;
    padding: 1.6rem;
    border: 1px solid var(--line);
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.82);
    opacity: 0.6;
    transform: scale(0.985);
    transition: opacity 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
  }

  .story-step.active {
    opacity: 1;
    transform: scale(1);
    border-color: rgba(79, 70, 229, 0.25);
    box-shadow: 0 18px 40px rgba(107, 114, 128, 0.08);
  }

  .story-step-copy {
    display: grid;
    gap: 1rem;
    align-content: center;
  }

  .story-kicker {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand);
  }

  .story-step h3 {
    margin: 0;
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    line-height: 1.4;
  }

  .story-step-image {
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 1rem;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 18px 44px rgba(107, 114, 128, 0.12);
  }

  .story-step-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .preview-features {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .feature-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    background: rgba(79, 70, 229, 0.12);
    color: var(--brand);
    border-radius: 50%;
    font-size: 0.85rem;
    font-weight: 700;
    margin-top: 0.1rem;
    flex-shrink: 0;
  }

  .feature-item p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.4;
    color: var(--ink);
  }

  @media (max-width: 1024px) {
    .story-layout {
      gap: 1.25rem;
    }

    .story-nav {
      grid-auto-flow: column;
      grid-auto-columns: minmax(240px, 1fr);
      grid-template-columns: none;
      overflow-x: auto;
      padding-bottom: 0.25rem;
    }

    .story-step {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .preview-features {
      gap: 0.8rem;
    }
  }

  @media (max-width: 680px) {
    .story-layout {
      margin-top: 1.4rem;
    }

    .story-topbar {
      top: 0;
      padding: 0.9rem;
      border-radius: 1rem;
    }

    .story-tab {
      padding: 0.8rem 0.85rem;
      min-width: 220px;
    }

    .story-tab-summary {
      font-size: 0.84rem;
    }

    .story-step {
      padding: 1rem;
      min-height: auto;
    }

    .feature-item p {
      font-size: 0.9rem;
    }
  }
</style>
