---
interface Props {
  copy: {
    headline: string;
    lead: string;
    pairs: Array<{ pain: string; solution: string }>;
  };
}

const { copy } = Astro.props;
---

<section id="pain" class="section">
  <div class="shell">
    <h2>{copy.headline}</h2>
    <p class="section-lead">{copy.lead}</p>

    <div class="pairs">
      {
        copy.pairs.map((item) => (
          <article class="pair-card">
            <p class="pair-pain">{item.pain}</p>
            <p class="pair-fix">{item.solution}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
