---
interface Props {
  copy: {
    solutionHeadline: string;
    solutionLead: string;
    solutions: Array<{ title: string; body: string }>;
    featureHeadline: string;
    features: Array<{ title: string; feature: string; benefit: string }>;
    resultsHeadline: string;
    beforeLabel: string;
    afterLabel: string;
    resultsRows: Array<{ before: string; after: string }>;
  };
  cta: {
    demo: string;
    line: string;
    trial: string;
  };
  links: {
    solutionDemo: string;
    featureLine: string;
    featureTrial: string;
  };
}

const { copy, cta, links } = Astro.props;
---

<section id="features" class="section alt">
  <div class="shell">
    <h2>{copy.solutionHeadline}</h2>
    <p class="section-lead">{copy.solutionLead}</p>

    <div class="cards two-cols">
      {
        copy.solutions.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))
      }
    </div>

    <div class="inline-cta">
      <a class="btn btn-solid" href={links.solutionDemo}>{cta.demo}</a>
    </div>

    <div class="section-divider"></div>

    <h2>{copy.featureHeadline}</h2>
    <div class="cards two-cols">
      {
        copy.features.map((item) => (
          <article class="card feature">
            <h3>{item.title}</h3>
            <p><strong>Feature:</strong> {item.feature}</p>
            <p><strong>Benefit:</strong> {item.benefit}</p>
          </article>
        ))
      }
    </div>

    <div class="inline-cta split">
      <a class="btn btn-solid" href={links.featureLine}>{cta.line}</a>
      <a class="btn btn-outline" href={links.featureTrial}>{cta.trial}</a>
    </div>

    <div id="results" class="section-inner">
      <h2>{copy.resultsHeadline}</h2>
      <div class="outcomes">
        <div class="outcome-row outcome-header">
          <p class="before-label">{copy.beforeLabel}</p>
          <span class="outcome-sep" aria-hidden="true"></span>
          <p class="after-label">{copy.afterLabel}</p>
        </div>
        {
          copy.resultsRows.map((row) => (
            <div class="outcome-row">
              <p class="before">{row.before}</p>
              <span class="outcome-sep" aria-hidden="true">→</span>
              <p class="after">{row.after}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
