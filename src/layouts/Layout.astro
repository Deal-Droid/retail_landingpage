---
interface Props {
	title?: string;
	description?: string;
	lang?: string;
}

const {
	title = 'DealDroid | AI Sales Chatbot for High-Volume Reseller Stores',
	description = 'DealDroid is an AI chatbot powered by LLM + RAG for reseller stores handling over 100K chats per month. Increase sales with 24/7 instant replies and seamless human handoff.',
	lang = 'en',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
